# ============================================================
#  WatsonX Credentials — copy this file to .env and fill in
#  your actual values. NEVER commit .env to git.
# ============================================================

# Your IBM Cloud API key (from cloud.ibm.com → Manage → Access → API keys)
WATSONX_APIKEY=your_ibm_cloud_api_key_here

# Your WatsonX project ID (from watsonx.ai → Project settings)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# WatsonX service URL (default: us-south; change if your instance is in another region)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
