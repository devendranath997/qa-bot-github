# ============================================================
#  .gitignore — files that must NEVER be committed to GitHub
# ============================================================

# --- Secrets & credentials (CRITICAL) ---
.env
*.pem
*.key
secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# --- Virtual environments ---
.venv/
venv/
ENV/
env/
.env.local
.env.*.local

# --- ChromaDB persistent storage ---
chroma_db/
.chroma/

# --- Uploaded / temp PDFs ---
*.pdf
uploads/
tmp/

# --- Jupyter ---
.ipynb_checkpoints
*.ipynb

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Test & coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/
